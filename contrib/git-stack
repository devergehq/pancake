#!/usr/bin/env bash
#
# git-stack — stateless stacked-PR management, derived from the git graph.
#
# No stored state, no config, no server, no account. The "stack" is derived
# every time from reachability in the commit graph, so it works identically in
# any clone — including throwaway APFS workspaces — from the first second.
#
# You provide two things you already know: the TOP branch of the stack and the
# TRUNK it targets (default origin/master). Everything else is computed.
#
# Usage:
#   git stack list   <top> [trunk]    # print the stack, bottom -> top
#   git stack log    <top> [trunk]    # show the stack as a decorated graph
#   git stack sync   <top> [trunk]    # fetch+prune, restack onto trunk, move every local ref
#   git stack submit <top> [trunk]    # force-push (with lease) every branch in the stack
#
#   <top>   short branch name, e.g. feature/dev-67  (no "origin/" prefix)
#   <trunk> defaults to origin/master
#
# sync options:
#   --from <ref>   start the restack from <ref> instead of auto-detecting the
#                  boundary. Escape hatch for when a squash-merged branch's local
#                  ref is gone (e.g. a fresh clone): pass its pre-merge tip.
#
# Typical loop after a PR at the bottom merges:
#   git stack sync   feature/dev-67
#   git stack submit feature/dev-67
#
set -euo pipefail

TRUNK_DEFAULT="origin/master"

die() { printf 'git-stack: %s\n' "$*" >&2; exit 1; }
note() { printf '\033[36m▸ %s\033[0m\n' "$*" >&2; }

usage() {
  sed -n '3,/^set -euo pipefail/p' "$0" | sed '$d; s/^# \{0,1\}//'
  exit "${1:-0}"
}

# Print every origin branch reachable from <top> but NOT from <trunk>, ordered
# bottom -> top by distance from trunk. This IS the stack — merged branches are
# gone from origin/* after fetch --prune, so they never appear.
stack_list() {
  local top="origin/$1" trunk="${2:-$TRUNK_DEFAULT}"
  git rev-parse --verify -q "$top" >/dev/null \
    || die "no remote-tracking branch '$top' — run a fetch, or check the name"
  git for-each-ref --merged "$top" --no-merged "$trunk" \
      --format='%(objectname) %(refname:lstrip=3)' refs/remotes/origin/ \
    | while read -r sha name; do
        printf '%s\t%s\n' "$(git rev-list --count "$trunk..$sha")" "$name"
      done | sort -n | cut -f2
}

cmd="${1:-}"; [ -n "$cmd" ] || usage 1
case "$cmd" in -h|--help|help) usage 0 ;; esac
shift

# Optional flags (currently just --from: an explicit rebase boundary for `sync`).
from=""
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    --from)   from="${2:?--from needs a <ref>}"; shift 2 ;;
    --from=*) from="${1#--from=}"; shift ;;
    *)        positional+=("$1"); shift ;;
  esac
done
set -- "${positional[@]}"

top="${1:-}"; [ -n "$top" ] || die "missing <top> branch (try: git stack $cmd feature/xxx)"
trunk="${2:-$TRUNK_DEFAULT}"

case "$cmd" in
  list)
    stack_list "$top" "$trunk"
    ;;

  log)
    git log --graph --oneline --decorate "$trunk..origin/$top"
    ;;

  sync)
    note "fetching + pruning origin"
    git fetch --prune origin
    # Check out the top branch in THIS worktree first (DWIM-creates a tracking
    # branch if it doesn't exist locally yet).
    git switch "$top" 2>/dev/null || git switch -c "$top" --track "origin/$top" \
      || die "can't switch to '$top' — is it checked out in another worktree?"
    note "materializing stack branches locally"
    stack_list "$top" "$trunk" | while read -r b; do
      # The top is HEAD — it gets rebased below, so never force-update it (git
      # refuses to force a checked-out branch). Skip it here.
      [ "$b" = "$top" ] && continue
      # A branch checked out in *another* worktree also can't be force-updated;
      # skip it with a warning rather than aborting the whole sync.
      if git branch --force "$b" "origin/$b" 2>/dev/null; then
        printf '   %s -> %s\n' "$b" "$(git rev-parse --short "origin/$b")" >&2
      else
        printf '   ! skipped %s (checked out in another worktree — align it there)\n' "$b" >&2
      fi
    done
    # Work out where to start the replay.
    #
    # Normally it's the fork point (merge-base with trunk): everything above the
    # fork replays onto the new trunk, and a single squash-merged commit already
    # in trunk drops as an empty replay.
    #
    # But a *multi-commit* branch that was squash-merged and then deleted upstream
    # collapses to one commit in trunk, so replaying its individual commits
    # conflicts (add/add on files it created). Git left its LOCAL ref behind while
    # pruning the remote — that local tip is exactly the boundary we want. So:
    # find local branches that (a) have no remote counterpart (merged & deleted)
    # and (b) are ancestors of HEAD (part of this stack), and start the replay
    # from the HIGHEST one, skipping the merged commits entirely.
    #
    # Escape hatch: if --from is given, trust it and skip auto-detection. Use this
    # when the merged branch's local ref is gone (e.g. a fresh clone) — pass the
    # tip of the squash-merged branch (a SHA, or grab it off the merged PR).
    if [ -n "$from" ]; then
      boundary="$(git rev-parse --verify "${from}^{commit}" 2>/dev/null)" \
        || die "--from: '$from' is not a valid commit/ref"
      note "using explicit boundary --from $from ($(git rev-parse --short "$boundary"))"
    else
      boundary="$(git merge-base "$trunk" HEAD)"
      for lb in $(git for-each-ref --format='%(refname:lstrip=2)' refs/heads/); do
        [ "$lb" = "$top" ] && continue
        git show-ref -q --verify "refs/remotes/origin/$lb" && continue   # still on the remote
        git merge-base --is-ancestor "$lb" HEAD || continue              # not part of this stack
        if git merge-base --is-ancestor "$boundary" "$lb"; then          # higher than current boundary
          boundary="$(git rev-parse "$lb")"
          note "squash-merged branch below the stack: $lb — dropping its commits"
        fi
      done
    fi
    note "restacking $top onto $trunk from $(git rev-parse --short "$boundary") (--update-refs)"
    git rebase --update-refs --onto "$trunk" "$boundary"
    note "done — review with: git stack log $top, then push: git stack submit $top"
    ;;

  submit)
    # shellcheck disable=SC2046  # branch names never contain whitespace
    branches=$(stack_list "$top" "$trunk")
    [ -n "$branches" ] || die "no stack branches found above $trunk"
    note "force-pushing: $(echo "$branches" | tr '\n' ' ')"
    # shellcheck disable=SC2086
    git push --force-with-lease origin $branches
    ;;

  *)
    die "unknown command '$cmd' (try: list, log, sync, submit)"
    ;;
esac
